# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Neon (pooled — use for the running app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Neon (direct — used automatically for migrate / makemigrations)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Hidden admin setup page: /setup/<ADMIN_SETUP_SECRET>/
ADMIN_SETUP_SECRET=change-me-to-a-long-random-string
