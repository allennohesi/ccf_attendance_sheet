# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Neon (pooled — use for the running app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Neon (direct — used automatically for migrate / makemigrations)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Vercel Blob (avatars / uploads on production)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
BLOB_STORE_ID=store_xxxxxxxx
